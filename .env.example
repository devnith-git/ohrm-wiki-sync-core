# Copy this file to `.env` and fill in real values.
# `.env` is gitignored. Never commit it.

# ---- Atlassian / Jira ----
# Your Atlassian account email and an API token from
# https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_USER=your.email@example.com
JIRA_API_TOKEN=replace-me

# Your Jira Cloud ID (UUID). Get this once via the Atlassian MCP
# `getAccessibleAtlassianResources` or from any issue URL.
ATLASSIAN_CLOUD_ID=00000000-0000-0000-0000-000000000000

# ---- Anthropic (Claude API) ----
# Required ONLY for `automation/sync.py` (standalone Python CLI).
# The routine (routines/deploy.py) uses your Claude.ai subscription,
# so it does NOT need this key — but `deploy.py` itself needs a key
# to call the RemoteTrigger create/update endpoint via the same auth.
ANTHROPIC_API_KEY=sk-ant-...

# ---- BookStack (Enterprise Wiki) ----
# Generate the token pair under your BookStack user profile.
# The user must have edit-page rights on every target chapter.
WIKI_TOKEN_ID=replace-me
WIKI_TOKEN_SECRET=replace-me
WIKI_BASE_URL=https://enterprisewiki.example.com

# ---- Routine deployment ----
# Anthropic environment to host the routine in. Default = anthropic_cloud.
ROUTINE_ENVIRONMENT_ID=env_01VQwdo2ZPUCQiu3YNY8rwzU
# When updating an existing routine, set this. Leave blank to create new.
ROUTINE_TRIGGER_ID=

# ---- Atlassian MCP connector UUID (for routine deployment) ----
# Get from `claude.ai/customize/connectors` or the /schedule skill listing.
ATLASSIAN_MCP_UUID=af43bc0a-a7ec-4b6a-b841-7e574624993f
WIKI_MCP_UUID=b6ed3c23-ccf2-4ebb-8d8a-ac2bf810496a

# ---- GitHub PAT for per-run log commits (optional, used by routines) ----
# Fine-grained PAT scoped to devnith-git/ohrm-wiki-sync with `contents:write`.
# Set this in the routine's Environment Variables section in the claude.ai UI
# so each scheduled run can commit a per-run log file under logs/<routine>/.
# If unset, routines still run but skip the log-commit step silently.
GITHUB_TOKEN=

# ---- Email notification (STEP 10, used by routines) ----
# Wired to the Gmail API over HTTPS (POST gmail.googleapis.com/.../send,
# authenticated by OAuth2 refresh-token flow). SMTP would not work —
# the claude.ai routines runtime firewalls outbound SMTP ports
# 25/465/587/2525 at the network layer (proven empirically, run
# 2026-05-15T12:46Z, errno=ETIMEDOUT with no TCP RST). HTTPS is allowed,
# so we use the Gmail API directly instead of SMTP. Same end result
# (email lands in the recipient's inbox), but uses your existing Google
# account / Workspace — no third-party vendor relationship.
#
# One-time setup: run `python routines/oauth_setup.py CLIENT_ID CLIENT_SECRET`
# locally to obtain the GOOGLE_REFRESH_TOKEN. See that script's docstring
# for the Google Cloud Console steps (enable Gmail API, create OAuth
# client, configure consent screen). Then set the four values below in
# the routine's Environment Variables in the claude.ai UI. If any are
# unset, STEP 10 prints a warning and the routine continues (the log
# file is already on GitHub).

# OAuth2 client ID from Google Cloud Console -> Credentials.
# Looks like 123456789-abc...apps.googleusercontent.com
GOOGLE_CLIENT_ID=replace-me.apps.googleusercontent.com

# OAuth2 client secret from the same OAuth client. Looks like GOCSPX-...
GOOGLE_CLIENT_SECRET=GOCSPX-replace-me

# Long-lived refresh token. Generate with routines/oauth_setup.py (one
# time, run locally). Does NOT expire if the OAuth consent screen is
# Internal (Workspace) or External + In production. Apps in
# External + Testing status get refresh tokens that expire after 7 days
# — use Internal/Workspace for production stability.
GOOGLE_REFRESH_TOKEN=1//replace-me

# Visible From address. MUST match the Gmail account that granted the
# refresh token (or a verified send-as alias in that account). Gmail
# rejects sends where the From doesn't match the authenticated user.
EMAIL_SENDER=replace-me@orangehrm.com

# Display name in the From header. Cosmetic.
EMAIL_FROM_NAME=OHRM Wiki Sync

# HTTP request timeout in seconds (defaults to 30 if unset).
GMAIL_TIMEOUT=30
