# OAuth client credentials cached by routines/oauth_setup.py.
# Holds CLIENT_ID + CLIENT_SECRET for fast re-mint of refresh tokens
# (the refresh token itself is NEVER cached — only lives in the
# routines UI). Each operator's laptop has its own copy.
.oauth_local.json
routines/.oauth_local.json

